# Frontend environment variables
VITE_API_URL=http://127.0.0.1:3001

# Backend environment variables
# Copy this file to .env and fill in your values

# Your HoverCode API token (from https://hovercode.com/settings/)
HOVERCODE_API_TOKEN=your_token_here

# Your HoverCode QR code ID (the ID in the QR code's URL)
QR_CODE_ID=your_qr_code_id_here

# Your Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key

# Port for the Express server (optional, defaults to 3001)
PORT=3001
